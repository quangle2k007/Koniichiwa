class Point:
    """Biểu diễn một điểm trong không gian 2D."""
    def __init__(self, x=0, y=0):
        self.x = x
        self.y = y
class Rectangle:
    """Biểu diễn một hình chữ nhật."""
    def __init__(self, width=0, height=0, corner=None):
        self.width = width
        self.height = height
